---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, category } = Astro.props;
---

<html lang="da">
  <head>
    <BaseHead title={`${title} | Sedumtage.dk`} description={description} />
  </head>
  <body>
    <Header />

    <article>
      <div class="article-hero">
        <div class="article-hero-inner">
          {category && <span class="pill">{category}</span>}
          <h1>{title}</h1>
          <p class="article-desc">{description}</p>
          <div class="article-meta">
            <FormattedDate date={pubDate} />
            {updatedDate && (
              <span> · Opdateret <FormattedDate date={updatedDate} /></span>
            )}
          </div>
        </div>
      </div>

      <div class="prose">
        <slot />
      </div>

      <div class="article-cta">
        <div class="cta-box">
          <p>Klar til at gå fra viden til handling? Beregn prisen på dit sedumtag.</p>
          <a href="https://nordic-rooftop.dk/udregn-tilbud/" target="_blank" rel="noopener">
            Beregn din pris →
          </a>
        </div>
      </div>
    </article>

    <Footer />
  </body>
</html>

<style>
.article-hero {
  background: var(--forest);
  padding: 4rem 2.5rem 3rem;
  position: relative;
  overflow: hidden;
}
.article-hero::after {
  content: '';
  position: absolute; bottom: -1px; left: 0; right: 0;
  height: 50px;
  background: var(--cream);
  clip-path: ellipse(55% 100% at 50% 100%);
}
.article-hero-inner {
  max-width: 720px;
  margin: 0 auto;
  position: relative;
  z-index: 1;
}
.article-hero .pill { margin-bottom: 1rem; }
.article-hero h1 {
  font-family: var(--font-serif);
  font-size: clamp(1.8rem, 4vw, 2.6rem);
  color: var(--cream);
  line-height: 1.2;
  margin-bottom: 0.75rem;
}
.article-desc {
  font-size: 1rem;
  color: rgba(245,240,232,0.7);
  max-width: 560px;
  margin-bottom: 1rem;
  font-weight: 300;
}
.article-meta {
  font-size: 0.78rem;
  color: rgba(245,240,232,0.4);
  font-weight: 400;
}

.article-cta {
  max-width: 720px;
  margin: 0 auto;
  padding: 0 2rem 4rem;
}
</style>
